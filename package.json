{
  "name": "starter-ts",
  "description": "📦️ Zero-config TypeScript template for rapid development. Pre-configured with modern tooling to start coding",
  "author": "Luis Monsalve",
  "version": "0.0.0",
  "homepage": "https://github.com/TheElegantCoding/starter-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheElegantCoding/starter-ts.git"
  },
  "keywords": [
    "typescript",
    "github",
    "git",
    "clean-code"
  ],
  "bugs": {
    "url": "https://github.com/TheElegantCoding/starter-ts/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["./dist"],
  "engines": {
    "node": ">=22.17.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "postinstall": "bunx gitlys init",
    "dev": "bunx tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --fix",
    "release": "bunx gitlys release"
  },
  "devDependencies": {
    "eslint-config-universal-code": "^1.0.14",
    "gitlys": "^1.1.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
